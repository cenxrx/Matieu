<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Matieu.MainWindow"
        Title="Матье"
        Width="1100" Height="650"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="BorderOnly"
        Background="White"
        Icon="avares://Matieu/Resources/Logo.ico">

    <Grid RowDefinitions="Auto,*">

        <!-- Верхняя панель с кнопками -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Height="50" Background="White">
            <TextBlock Grid.Column="0" Text="Матье" 
                       VerticalAlignment="Center" Margin="15,0" FontSize="14"/>
            <Button Grid.Column="2" Name="minimizeBtn" Content="Свернуть"
                    Height="30" Padding="15,0" Margin="5" 
                    Background="White" Foreground="Black" 
                    BorderBrush="Black" BorderThickness="1"/>
            <Button Grid.Column="3" Name="closeBtn" Content="Закрыть"
                    Height="30" Padding="15,0" Margin="5,5,15,5"
                    Background="White" Foreground="Black" 
                    BorderBrush="Black" BorderThickness="1"/>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="180,*,180">

            <!-- Левая панель -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto,Auto" Background="White" Margin="15,0,0,15">
                <Border Grid.Row="0" BorderBrush="Black"
                        BorderThickness="1" Height="120" Width="150" Margin="0,0,0,15">
                    <Image Name="logoImage" Source="avares://Matieu/Resources/Logo.ico" 
                           Stretch="Uniform" Margin="10"/>
                </Border>

                <StackPanel Grid.Row="2" Margin="0,0,0,15">
                    <Button Name="servicesBtn" Content="Услуги"
                            HorizontalAlignment="Stretch" Height="35" Margin="0,0,0,10"
                            Background="White" Foreground="Black" 
                            BorderBrush="Black" BorderThickness="1"/>
                    <Button Name="addServiceBtn" Content="Добавить услугу"
                            HorizontalAlignment="Stretch" Height="35" Margin="0,0,0,10"
                            Background="White" Foreground="Black" 
                            BorderBrush="Black" BorderThickness="1"
                            IsVisible="False"/>
                </StackPanel>

                <Button Grid.Row="3" Name="logoutBtn" Content="Выход"
                        HorizontalAlignment="Stretch" Height="35"
                        Background="White" Foreground="Black" 
                        BorderBrush="Black" BorderThickness="1"/>
            </Grid>

            <!-- Центральная панель -->
            <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" Margin="15,0,15,15">
                <TabControl Grid.Row="0" Name="categoryTabs" Margin="0,0,0,10" 
                            Background="White" BorderThickness="0">
                    <TabItem Header="Кастом" FontSize="13"/>
                    <TabItem Header="Косплей" FontSize="13"/>
                </TabControl>

                <ScrollViewer Grid.Row="1">
                    <StackPanel Name="servicesPanel" Spacing="10"/>
                </ScrollViewer>

                <Border Grid.Row="2" BorderBrush="Black" BorderThickness="1" 
                        Height="30" Margin="0,10,0,0" Padding="8,0">
                    <TextBlock Name="pageInfo" VerticalAlignment="Center" FontSize="12"/>
                </Border>
            </Grid>

            <!-- Правая панель -->
            <Grid Grid.Column="2" RowDefinitions="Auto,Auto,Auto,*" Margin="0,0,15,15">
                <TextBox Grid.Row="0" Name="searchBox" Watermark="Поиск"
                         Height="30" Margin="0,0,0,10"
                         Background="White" BorderBrush="Black" BorderThickness="1"/>
                <ComboBox Grid.Row="1" Name="collectionFilter"
                          HorizontalAlignment="Stretch" Height="30" Margin="0,0,0,15"
                          Background="White" BorderBrush="Black" BorderThickness="1"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                    <Button Name="prevBtn" Content="◄" Width="50" Height="50"
                            Background="White" Foreground="Black" 
                            BorderBrush="Black" BorderThickness="1" FontSize="18"/>
                    <Button Name="nextBtn" Content="►" Width="50" Height="50"
                            Background="White" Foreground="Black" 
                            BorderBrush="Black" BorderThickness="1" FontSize="18"/>
                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</Window>
